# Microsoft Azure AD OAuth
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# SAP Business One — Service Layer (environnement PROD)
SAP_B1_BASE_URL=https://HOST:50000/b1s/v1
SAP_B1_COMPANY_DB=SBO_PROD
SAP_B1_USERNAME=
SAP_B1_PASSWORD=
SAP_B1_TLS_INSECURE=0

# SAP environnement TEST (bouton de bascule prod↔test dans la navbar).
# Seul SAP_B1_COMPANY_DB_TEST est requis pour activer la bascule ; base/user/pass
# retombent sur les valeurs PROD si non renseignés (même serveur, autre société).
SAP_B1_COMPANY_DB_TEST=SBO_TEST
# SAP_B1_BASE_URL_TEST=
# SAP_B1_USERNAME_TEST=
# SAP_B1_PASSWORD_TEST=

# Relance / recouvrement des encours (NT-2026-RC-01)
# Expéditeur : boîte partagée, envoyée via l'IDENTITÉ APPLICATIVE (client
# credentials = AZURE_CLIENT_ID/SECRET/TENANT_ID ci-dessus). Prérequis Azure :
# permission d'APPLICATION Microsoft Graph « Mail.Send » + consentement admin,
# et (recommandé) une ApplicationAccessPolicy Exchange limitant l'app à cette
# seule boîte. Aucun scope délégué ni reconnexion utilisateur requis.
RELANCE_FROM_ADDRESS=compta@gervifrais.com
# Par défaut (RELANCE_LIVE absent), TOUTES les relances sont redirigées vers une
# boîte de test — aucun email n'atteint les vrais débiteurs. Pour l'envoi réel
# (vers Client.emailCompta), positionner RELANCE_LIVE=1.
RELANCE_TEST_RECIPIENT=wahofef603@aratrin.com
# RELANCE_LIVE=1
# Pièce jointe « PDF de la facture » (Crystal) : URL d'un service externe qui rend
# le PDF par DocEntry (cf. docs/crystal-pdf-service). Tant que c'est vide, aucune
# pièce jointe n'est ajoutée (comportement inchangé).
# RELANCE_INVOICE_PDF_URL=https://sap-host:5001/invoice-pdf
# RELANCE_INVOICE_PDF_KEY=

# ── Notifications push (PWA) ────────────────────────────────────────────────
# Générer une paire de clés : `npx web-push generate-vapid-keys`
# Tant que ces 2 clés sont absentes, les notifications sont désactivées (aucune
# régression : la console fonctionne, le bouton « Notifs » est masqué).
# NB. Pas de cron : les push de rappels sont déclenchés côté client quand la
# console est ouverte (/api/push/flush), Vercel Hobby limitant les crons à 1/j.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact requis par le protocole Web-Push (mailto: ou https:).
VAPID_SUBJECT=mailto:admin@gervifrais.fr

# ── Congés / récup : notifications employeur (onglet Planning) ──────────────
# EMAIL au patron à chaque demande de congés/récup — envoyé DEPUIS cette boîte
# via l'identité applicative Graph (permission d'application « Mail.Send »,
# comme les relances). À défaut, repli sur RELANCE_FROM_ADDRESS ; si les deux
# sont vides, pas d'email (le push in-app reste actif).
# CONGES_FROM_ADDRESS=rh@gervifrais.com
# CALENDRIER OUTLOOK : un congé VALIDÉ est poussé dans le calendrier Outlook de
# chaque membre de la direction. Prérequis Azure : permission d'APPLICATION
# Microsoft Graph « Calendars.ReadWrite » + consentement admin (sinon l'étape
# est ignorée, erreur 403 en logs).
# WHATSAPP (Meta Cloud API) — facultatif : message au patron à chaque demande,
# avec lien vers l'app. Nécessite un compte WhatsApp Business (Meta for
# Developers) : jeton permanent + Phone Number ID. Hors fenêtre de service de
# 24 h, Meta impose un TEMPLATE approuvé : créer un modèle dont le corps est
# « {{1}} » et renseigner WHATSAPP_TEMPLATE_NAME (sinon message texte simple).
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_DIRECTION_TO=+33612345678,+33698765432
# WHATSAPP_TEMPLATE_NAME=
# WHATSAPP_TEMPLATE_LANG=fr
# URL publique de l'app (liens des emails / WhatsApp) — défaut : NEXTAUTH_URL.
# APP_PUBLIC_URL=https://televent.gervifrais.com
